{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar mini banco",
            "type": "shell",
            "command": "g++",
            "args": [
                "-Wall",
                "-Wextra",
                "-g3",
                "${workspaceFolder}/src/main.cpp",
                "${workspaceFolder}/src/conta.cpp",
                "-I",
                "${workspaceFolder}/include",
                "-o",
                "${workspaceFolder}/src/output/main.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Executar mini banco",
            "type": "shell",
            "command": "${workspaceFolder}/src/output/main.exe",
            "dependsOn": "Compilar mini banco",
            "problemMatcher": []
        }
    ]
}